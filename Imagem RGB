def processa_banda(lista_arquivos, master_flat, master_bias, ref_data):
    if not lista_arquivos: return None
    imagens_alinhadas = []
    for arquivo in lista_arquivos:
        dados_reduzidos = reduz_imagem(arquivo, master_bias, master_flat)
        try:
            alinhada, _ = aa.register(dados_reduzidos, ref_data)
            imagens_alinhadas.append(alinhada)
        except Exception as e:
            print(f"Aviso: Não foi possível alinhar {os.path.basename(arquivo)}: {e}. Usando sem alinhamento.")
            imagens_alinhadas.append(dados_reduzidos)
    return np.median(imagens_alinhadas, axis=0)

M104_R_empilhada = processa_banda(dicionario_objeto['R'], master_flats['R'], master_bias, ref_data)
M104_V_empilhada = processa_banda(dicionario_objeto['V'], master_flats['V'], master_bias, ref_data)
